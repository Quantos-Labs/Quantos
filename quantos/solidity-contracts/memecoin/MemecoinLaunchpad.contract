{
  "contract": {
    "authors": [
      "unknown"
    ],
    "description": "MemecoinLaunchpad — Pump.fun-style bonding curve on Quantos\nVirtual-AMM (constant product) bonding curve. 0.5 % trade fee → creator.\nMigration to DEX when QTEST raised ≥ target.\nTokenomics per memecoin (1 B total supply):\n80 %  bonding curve   (800 M)\n10 %  creator vesting (100 M) — 1 yr cliff then 5 %/month\n5 %  DEX liquidity   ( 50 M) — released at migration\n5 %  platform        ( 50 M) — sent to Vybss wallet immediately",
    "name": "MemecoinLaunchpad",
    "version": "0.0.1"
  },
  "source": {
    "compiler": "solang 0.3.3",
    "hash": "0xcd685c6855614dda933f87812b7a79f84d9c4573f832863406730a3b6a9687ba",
    "language": "Solidity 0.3.3",
    "wasm": ""
  },
