          }
        ],
        "default": false,
        "docs": [
          "Stake `amount` QTEST. Requires prior `qtest.approve(this, amount)`."
        ],
        "label": "stake",
        "mutates": true,
        "payable": false,
        "returnType": null,
        "selector": "0xa694fc3a"
      },
      {
        "args": [
          {
            "label": "amount",
            "type": {
              "displayName": [
                "uint256"
              ],
              "type": 5
            }
          }
        ],
        "default": false,
        "docs": [
          "Reduce active stake by `amount`. If unbondingSeconds == 0 the QTEST is\ntransferred back immediately. Otherwise it's queued in `pendingOf` and\nmust be claimed via `withdrawPending()` once `availableAt` has passed."
        ],
        "label": "unstake",
        "mutates": true,
        "payable": false,
        "returnType": null,
        "selector": "0x2e17de78"
      },
      {
        "args": [],
        "default": false,
        "docs": [
          "Claim pending unbonded QTEST. Reverts if no pending or still in cooldown."
        ],
        "label": "withdrawPending",
        "mutates": true,
        "payable": false,
        "returnType": null,
        "selector": "0x7edbceb1"
      },
