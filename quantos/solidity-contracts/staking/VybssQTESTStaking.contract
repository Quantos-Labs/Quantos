              ],
              "type": 2
            }
          }
        ],
        "default": false,
        "docs": [
          "Bundled view used by the wallet-server / UI to render the staking\ndashboard in a single read. Only touches local state — wallet-side\nbalance/allowance are fetched separately from the QTEST contract\nso this view never reverts because of cross-contract issues."
        ],
        "label": "getInfo",
        "mutates": false,
        "payable": false,
        "returnType": {
          "displayName": [
            "VybssQTESTStaking",
            "getInfo",
            "return_type"
          ],
          "type": 8
        },
        "selector": "0xffdd5cf1"
      }
