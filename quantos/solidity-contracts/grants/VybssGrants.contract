        "docs": [
          "Distribute matching funds to a project. Called by admin after QF calculation.\nThe matching amounts are calculated off-chain (Supabase RPC) using the\nCLR formula: matching_i = (sum_j sqrt(c_ij))^2 normalized to the pool."
        ],
        "label": "distributeMatching",
        "mutates": true,
        "payable": false,
        "returnType": null,
        "selector": "0x6010594d"
      },
      {
        "args": [
          {
            "label": "_roundId",
            "type": {
              "displayName": [
                "uint256"
              ],
              "type": 3
            }
          },
          {
