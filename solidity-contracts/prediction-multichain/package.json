{
  "name": "@quantos/prediction-multichain-contracts",
  "version": "1.0.0",
  "description": "Multichain prediction market contracts for Base, Arbitrum, BSC, Polygon and HyperEVM",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:arbitrum": "hardhat run scripts/deploy.ts --network arbitrum",
    "deploy:bsc": "hardhat run scripts/deploy.ts --network bsc",
    "deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "deploy:hyperevm": "hardhat run scripts/deploy.ts --network hyperevm",
    "deploy:base-testnet": "hardhat run scripts/deploy.ts --network baseTestnet",
    "deploy:arbitrum-testnet": "hardhat run scripts/deploy.ts --network arbitrumTestnet",
    "deploy:bsc-testnet": "hardhat run scripts/deploy.ts --network bscTestnet",
    "deploy:polygon-testnet": "hardhat run scripts/deploy.ts --network polygonTestnet",
    "deploy:hyperevm-testnet": "hardhat run scripts/deploy.ts --network hyperevmTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.1",
    "hardhat": "^2.19.0",
    "typescript": "^5.3.0"
  }
}
