# ============================================================================
# Quantos Node — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your deployment.
# Each validator operator configures these independently.
# ============================================================================

# --- Rate Limiting (per-IP, enforced via HTTP middleware) ---
# Requests per minute per client IP
QUANTOS_RATE_LIMIT_PER_MINUTE=100
# Burst allowance on top of per-minute limit
QUANTOS_RATE_LIMIT_BURST=20
# Ban duration in seconds for IPs exceeding the ban threshold
QUANTOS_BAN_DURATION_SECS=300
# Total requests in ban window before IP is banned
QUANTOS_BAN_THRESHOLD=500

# --- RPC ---
# Max transactions per batch submission
QUANTOS_RPC_MAX_BATCH_SIZE=2000

# --- Node ---
QUANTOS_RPC_PORT=8545
QUANTOS_P2P_PORT=30303
QUANTOS_METRICS_PORT=9615
QUANTOS_SHARDS=1000
QUANTOS_COMMITTEES=1000
RUST_LOG=info

# --- Performance ---
QUANTOS_MAX_CONCURRENT_EXECUTIONS=128
